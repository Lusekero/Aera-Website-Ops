cmd_target_secrets_generate() {
  local target="$1"
  shift || true

  local profile="prod"
  local show_values="false"
  local format="hex"
  local bytes="32"
  local secrets=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --profile=*) profile="${1#*=}" ;;
      --profile)
        shift
        profile="${1:-}"
        ;;
      --secret=*) secrets+=("${1#*=}") ;;
      --secret)
        shift
        secrets+=("${1:-}")
        ;;
      --format=*) format="${1#*=}" ;;
      --format)
        shift
        format="${1:-}"
        ;;
      --bytes=*) bytes="${1#*=}" ;;
      --bytes)
        shift
        bytes="${1:-}"
        ;;
      --show) show_values="true" ;;
      *) fail "Unknown ${target}:secrets:generate option: $1" ;;
    esac
    shift || true
  done

  case "${profile,,}" in
    dev|development) profile="dev" ;;
    prod|production) profile="prod" ;;
    *) fail "${target}:secrets:generate requires --profile=dev|prod" ;;
  esac

  case "${format,,}" in
    hex|base64) ;;
    *) fail "${target}:secrets:generate supports --format=hex|base64" ;;
  esac

  [[ "$bytes" =~ ^[0-9]+$ ]] || fail "${target}:secrets:generate requires --bytes as a positive integer"
  [ "$bytes" -gt 0 ] || fail "${target}:secrets:generate requires --bytes > 0"
  [ "${#secrets[@]}" -gt 0 ] || fail "${target}:secrets:generate requires at least one --secret KEY"

  require_cmd openssl

  local set_args=()
  local output_lines=()
  local key value
  for key in "${secrets[@]}"; do
    is_valid_env_key "$key" || fail "Invalid env key: $key"
    if [ "${format,,}" = "base64" ]; then
      value=$(openssl rand -base64 "$bytes")
    else
      value=$(openssl rand -hex "$bytes")
    fi
    set_args+=(--set "${key}=${value}")
    output_lines+=("${key}=${value}")
  done

  cmd_env_set --target "$target" --profile "$profile" "${set_args[@]}"

  if is_true "$show_values"; then
    echo "Generated ${target} secrets in profile=$profile"
    printf '%s\n' "${output_lines[@]}"
  else
    log "Generated ${#secrets[@]} ${target} secret key(s) in profile=$profile"
    warn "Values were written to env file and hidden in output. Use --show only in a secure terminal session if you need to see them."
  fi
}

