  info "Starting backend stack"
  dc --env-file "$BACKEND_ENV" -f "$BACKEND_COMPOSE" up -d
  log "Backend start command complete"
}

cmd_backend_build() {
  ensure_prerequisites
  local build_args=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --no-cache)
        build_args+=(--no-cache)
        ;;
      *)
        fail "Unknown option for backend:build: $1 (supported: --no-cache)"
        ;;
    esac
    shift
  done

  info "Building backend images"
  dc --env-file "$BACKEND_ENV" -f "$BACKEND_COMPOSE" build "${build_args[@]}"
  log "Backend build command complete"
}

run_client_script() {
  (cd "$CLIENT_DIR" && bash ./scripts/aera "$@")
}

run_proxy_make_target() {
  (cd "$PROXY_DIR" && make "$@")
}

cmd_backend_wait() {
  ensure_prerequisites
  wait_backend_healthy
}

cmd_client_cmd() {
  ensure_client_prerequisites
  [ "$#" -gt 0 ] || fail "Usage: ./aera client:cmd <client-command> [args...]"
  run_client_script "$@"
}

cmd_edge_cmd() {
  ensure_proxy_prerequisites
  [ "$#" -gt 0 ] || fail "Usage: ./aera edge:cmd <make-target> [args...]"
  run_proxy_make_target "$@"
}

cmd_backend_retry() {
  ensure_prerequisites
  warn "Waiting ${RETRY_PAUSE_SECONDS}s before retrying backend startup"
  sleep "$RETRY_PAUSE_SECONDS"
  cmd_backend_up
  cmd_backend_wait
}

cmd_client_up() {
  ensure_prerequisites
  local compose_args=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --build)
        compose_args+=(--build)
        ;;
      *)
        fail "Unknown option for client:up: $1 (supported: --build)"
        ;;
    esac
    shift
  done

  if ! all_backend_healthy; then
    fail "Backend is not fully healthy. Run ./aera backend:wait (or backend:retry) first."
  fi
  info "Starting client stack on shared network: $NETWORK_NAME"
  AERA_SHARED_NETWORK="$NETWORK_NAME" dc --env-file "$CLIENT_ENV" -f "$CLIENT_COMPOSE" up -d "${compose_args[@]}"
  log "Client start command complete"
}

