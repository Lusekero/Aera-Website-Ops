#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -d "$SCRIPT_DIR/backend" ] && [ -d "$SCRIPT_DIR/client" ] && [ -d "$SCRIPT_DIR/proxy" ]; then
  ROOT_DIR="$SCRIPT_DIR"
elif [ -d "$SCRIPT_DIR/../backend" ] && [ -d "$SCRIPT_DIR/../client" ] && [ -d "$SCRIPT_DIR/../proxy" ]; then
  ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
else
  ROOT_DIR="$SCRIPT_DIR"
fi
BACKEND_DIR="$ROOT_DIR/backend"
CLIENT_DIR="$ROOT_DIR/client"
PROXY_DIR="$ROOT_DIR/proxy"

BACKEND_ENV_DEV="$BACKEND_DIR/.env"
BACKEND_ENV="$BACKEND_DIR/.env.production"
CLIENT_ENV_DEV="$CLIENT_DIR/.env"
CLIENT_ENV="$CLIENT_DIR/.env.production"
PROXY_ENV_DEV="$PROXY_DIR/dev/.env.edge.dev"
PROXY_ENV="$PROXY_DIR/prod/.env.edge.prod"
BACKEND_COMPOSE="$BACKEND_DIR/docker-compose.production.yml"
CLIENT_COMPOSE="$CLIENT_DIR/docker-compose.prod.yml"
EDGE_COMPOSE="$PROXY_DIR/prod/docker-compose.edge.prod.yml"
BACKEND_SCRIPT="$BACKEND_DIR/scripts/aera"
CLIENT_SCRIPT="$CLIENT_DIR/scripts/aera"
MAINTENANCE_DIR="$PROXY_DIR/prod/nginx/maintenance"
MAINTENANCE_FLAG="$MAINTENANCE_DIR/enabled"

NETWORK_NAME="${AERA_SHARED_NETWORK:-aera_network_prod}"
WAIT_SECONDS="${AERA_WAIT_SECONDS:-600}"
RETRY_PAUSE_SECONDS="${AERA_RETRY_PAUSE_SECONDS:-300}"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

log() { echo -e "${GREEN}[aera]${NC} $*"; }
info() { echo -e "${BLUE}[aera] INFO:${NC} $*"; }
warn() { echo -e "${YELLOW}[aera] WARN:${NC} $*"; }
fail() { echo -e "${RED}[aera] ERROR:${NC} $*" >&2; exit 1; }

is_true() {
  case "${1:-}" in
    true|TRUE|1|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "Missing required command: $1"
}

require_file() {
  [ -f "$1" ] || fail "Missing required file: $1"
}

escape_sed_replacement() {
  printf '%s' "$1" | sed -e 's/[\/&]/\\&/g'
}

is_valid_env_key() {
  [[ "${1:-}" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]
}

env_resolve_file() {
  local target="$1"
  local profile="$2"

  case "${target,,}" in
    backend)
      case "${profile,,}" in
        dev|development) echo "$BACKEND_ENV_DEV" ;;
        prod|production) echo "$BACKEND_ENV" ;;
        *) fail "Unsupported profile for backend: $profile (use dev|prod)" ;;
      esac
      ;;
    client)
      case "${profile,,}" in
        dev|development) echo "$CLIENT_ENV_DEV" ;;
        prod|production) echo "$CLIENT_ENV" ;;
        *) fail "Unsupported profile for client: $profile (use dev|prod)" ;;
      esac
      ;;
    proxy)
      case "${profile,,}" in
        dev|development) echo "$PROXY_ENV_DEV" ;;
        prod|production) echo "$PROXY_ENV" ;;
        *) fail "Unsupported profile for proxy: $profile (use dev|prod)" ;;
      esac
      ;;
    *)
      fail "Unsupported target: $target (use backend|client|proxy)"
      ;;
  esac
}

env_ensure_file_exists() {
  local env_file="$1"
  if [ -f "$env_file" ]; then
    return 0
  fi

  mkdir -p "$(dirname "$env_file")"
  if [ -f "${env_file}.example" ]; then
    cp "${env_file}.example" "$env_file"
    info "Created env file from template: $env_file"
  else
    touch "$env_file"
    info "Created env file: $env_file"
  fi
}

env_set_value_in_file() {
  local env_file="$1"
  local key="$2"
  local value="$3"
  local escaped

  escaped=$(escape_sed_replacement "$value")
  if grep -q -E "^${key}=" "$env_file"; then
    sed -i "s|^${key}=.*|${key}=${escaped}|" "$env_file"
  else
    printf "%s=%s\n" "$key" "$value" >> "$env_file"
  fi
}

env_get_value_from_file() {
  local env_file="$1"
  local key="$2"
  grep -E "^${key}=" "$env_file" 2>/dev/null | tail -n1 | cut -d'=' -f2- || true
}

env_unset_key_in_file() {
  local env_file="$1"
  local key="$2"
  sed -i "/^${key}=.*/d" "$env_file"
}

dc() {
  docker compose "$@"
}

status_of() {
  docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}{{.State.Status}}{{end}}' "$1" 2>/dev/null || true
}

all_backend_healthy() {
  [ "$(status_of aera-mongo-prod)" = "healthy" ] \
    && [ "$(status_of aera-redis-prod)" = "healthy" ] \
    && [ "$(status_of aera-rabbitmq-prod)" = "healthy" ] \
    && [ "$(status_of aera-api-prod)" = "healthy" ]
}

wait_backend_healthy() {
  local deadline now
  deadline=$(( $(date +%s) + WAIT_SECONDS ))

  info "Waiting for backend health checks (timeout: ${WAIT_SECONDS}s)"
  while true; do
    if all_backend_healthy; then
      log "Backend services are healthy (mongo, redis, rabbitmq, api)"
      return 0
    fi

    printf '[aera] pending health: mongo=%s redis=%s rabbitmq=%s api=%s\n' \
      "$(status_of aera-mongo-prod)" \
      "$(status_of aera-redis-prod)" \
      "$(status_of aera-rabbitmq-prod)" \
      "$(status_of aera-api-prod)"

    now=$(date +%s)
    if [ "$now" -ge "$deadline" ]; then
      fail "Timeout while waiting for backend health checks"
    fi
    sleep 5
  done
}

ensure_prerequisites() {
  require_cmd docker
  require_file "$BACKEND_COMPOSE"
  require_file "$CLIENT_COMPOSE"
  require_file "$EDGE_COMPOSE"
  require_file "$BACKEND_ENV"
