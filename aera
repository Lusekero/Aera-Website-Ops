    shift
  done

  info "Building client image"
  AERA_SHARED_NETWORK="$NETWORK_NAME" dc --env-file "$CLIENT_ENV" -f "$CLIENT_COMPOSE" build "${build_args[@]}" nuxt-prod
  log "Client build command complete"
