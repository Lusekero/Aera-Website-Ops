}

reload_edge_nginx() {
  if docker ps --format '{{.Names}}' | grep -qx 'aera-edge-prod'; then
    dc -f "$EDGE_COMPOSE" exec -T aera-edge-prod nginx -s reload >/dev/null 2>&1 || \
      dc -f "$EDGE_COMPOSE" restart aera-edge-prod >/dev/null
  else
    warn "aera-edge-prod is not running; maintenance flag updated only"
  fi
}

cmd_maintenance_on() {
  mkdir -p "$MAINTENANCE_DIR"
  dc -f "$EDGE_COMPOSE" up -d aera-edge-prod >/dev/null 2>&1 || true
  touch "$MAINTENANCE_FLAG"
  reload_edge_nginx
  log "Maintenance mode enabled"
}

cmd_maintenance_off() {
  rm -f "$MAINTENANCE_FLAG"
  reload_edge_nginx
  log "Maintenance mode disabled"
}

cmd_maintenance_status() {
  if [ -f "$MAINTENANCE_FLAG" ]; then
    echo "maintenance: ON"
  else
    echo "maintenance: OFF"
  fi
}

cmd_smtp_configure() {
  ensure_backend_prerequisites

  local provider="custom"
  local host=""
  local port=""
  local secure=""
  local user=""
  local password=""
  local from=""
  local restart_backend="true"
  local restart_mode="api-worker"
  local arg

  for arg in "$@"; do
    case "$arg" in
      --provider=*) provider="${arg#*=}" ;;
      --host=*) host="${arg#*=}" ;;
      --port=*) port="${arg#*=}" ;;
      --secure=*) secure="${arg#*=}" ;;
      --user=*) user="${arg#*=}" ;;
      --password=*) password="${arg#*=}" ;;
      --from=*) from="${arg#*=}" ;;
      --restart) restart_backend="true" ;;
      --no-restart) restart_backend="false" ;;
      --worker-only) restart_mode="worker-only" ;;
      *) fail "Unknown smtp:configure option: $arg" ;;
    esac
  done

  case "${provider,,}" in
    gmail)
      host="${host:-smtp.gmail.com}"
      port="${port:-587}"
      secure="${secure:-false}"
      ;;
    m365|office365|outlook)
      host="${host:-smtp.office365.com}"
      port="${port:-587}"
      secure="${secure:-false}"
      ;;
    cpanel)
      port="${port:-587}"
      secure="${secure:-false}"
      ;;
    custom)
      ;;
    *)
      fail "Unsupported provider: $provider (use gmail|m365|outlook|office365|cpanel|custom)"
      ;;
  esac

  [ -n "$host" ] || fail "smtp:configure requires --host (or provider preset with default host)"
  [ -n "$port" ] || fail "smtp:configure requires --port"
  [ -n "$user" ] || fail "smtp:configure requires --user"
  [ -n "$password" ] || fail "smtp:configure requires --password"

  if [ -z "$secure" ]; then
    if [ "$port" = "465" ]; then
      secure="true"
    else
      secure="false"
    fi
  fi

  if [ -z "$from" ]; then
    from="\"Atomic Energy Regulatory Authority\" <${user}>"
  fi

  info "Writing SMTP settings to backend .env.production"
  (
    cd "$BACKEND_DIR"
    bash ./scripts/aera env:set:prod \
      --set "EMAIL_HOST=${host}" \
      --set "EMAIL_PORT=${port}" \
      --set "EMAIL_SECURE=${secure}" \
      --set "EMAIL_USER=${user}" \
      --set "EMAIL_PASSWORD=${password}" \
      --set "EMAIL_FROM=${from}"
  )
  log "SMTP configuration saved (provider=${provider}, host=${host}, port=${port}, secure=${secure})"

  if is_true "$restart_backend"; then
    if [ "$restart_mode" = "worker-only" ]; then
      info "Recreating backend runtime service (aera-worker) to apply SMTP changes"
      dc --env-file "$BACKEND_ENV" -f "$BACKEND_COMPOSE" up -d aera-worker
      warn "API container was not recreated (--worker-only). Use only when you are sure mail is sent from worker paths."
    else
      info "Recreating backend runtime services (aera-api, aera-worker) to apply SMTP changes"
      dc --env-file "$BACKEND_ENV" -f "$BACKEND_COMPOSE" up -d aera-api aera-worker
    fi
  else
    warn "SMTP updated but backend not restarted (--no-restart used)"
  fi
}

cmd_smtp_test() {
  ensure_backend_prerequisites

  local to=""
  local subject="AERA SMTP test email"
  local arg

  for arg in "$@"; do
    case "$arg" in
      --to=*) to="${arg#*=}" ;;
      --subject=*) subject="${arg#*=}" ;;
      *) fail "Unknown smtp:test option: $arg" ;;
    esac
  done

  local recipient="$to"
  if [ -z "$recipient" ]; then
    recipient=$(grep -E '^EMAIL_USER=' "$BACKEND_ENV" | tail -n1 | cut -d'=' -f2-)
  fi
  [ -n "$recipient" ] || fail "smtp:test needs --to=<email> or EMAIL_USER in $BACKEND_ENV"

  if ! docker ps --format '{{.Names}}' | grep -qx 'aera-api-prod'; then
    fail "Container aera-api-prod is not running. Start backend first with ./aera backend:up"
  fi

  info "Sending SMTP test email to $recipient via aera-api-prod"
  docker exec -e SMTP_TEST_TO="$recipient" -e SMTP_TEST_SUBJECT="$subject" aera-api-prod node -e "const nodemailer=require('nodemailer');const host=process.env.EMAIL_HOST;const port=Number(process.env.EMAIL_PORT||'587');const secure=(String(process.env.EMAIL_SECURE||'').toLowerCase()==='true')||(port===465);const user=process.env.EMAIL_USER;const pass=process.env.EMAIL_PASSWORD;const from=process.env.EMAIL_FROM||user;const to=process.env.SMTP_TEST_TO||user;const sub=process.env.SMTP_TEST_SUBJECT||'AERA SMTP test email';if(!host||!user||!pass){console.error('Missing EMAIL_HOST/EMAIL_USER/EMAIL_PASSWORD in container env');process.exit(1);}const t=nodemailer.createTransport({host,port,secure,auth:{user,pass}});t.sendMail({from,to,subject:sub,text:'SMTP test from AERA at '+new Date().toISOString()}).then(info=>{console.log('SMTP test mail queued:',info.messageId);}).catch(err=>{console.error('SMTP test failed:',err.message);process.exit(1);});"
  log "SMTP test command completed"
}

