  AERA_SHARED_NETWORK="$NETWORK_NAME" dc --env-file "$CLIENT_ENV" -f "$CLIENT_COMPOSE" down
  log "Client stop command complete"
}

cmd_client_restart() {
  ensure_prerequisites
