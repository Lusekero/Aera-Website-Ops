cmd_env_set() {
  local target=""
  local profile=""
  local env_file=""
  local pairs=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --target=*) target="${1#*=}" ;;
      --target)
        shift
        target="${1:-}"
        ;;
      --profile=*) profile="${1#*=}" ;;
      --profile)
        shift
        profile="${1:-}"
        ;;
      --set=*) pairs+=("${1#*=}") ;;
      --set)
        shift
        pairs+=("${1:-}")
        ;;
      *) fail "Unknown env:set option: $1" ;;
    esac
    shift || true
  done

  [ -n "$target" ] || fail "env:set requires --target=backend|client|proxy"
  [ -n "$profile" ] || fail "env:set requires --profile=dev|prod"
  [ "${#pairs[@]}" -gt 0 ] || fail "env:set requires at least one --set KEY=VALUE"

  env_file=$(env_resolve_file "$target" "$profile")
  env_ensure_file_exists "$env_file"

  local pair key value
  for pair in "${pairs[@]}"; do
    if [[ "$pair" != *=* ]]; then
      fail "Invalid --set value: $pair (expected KEY=VALUE)"
    fi
    key="${pair%%=*}"
    value="${pair#*=}"
    is_valid_env_key "$key" || fail "Invalid env key: $key"
    env_set_value_in_file "$env_file" "$key" "$value"
  done

  log "Updated ${#pairs[@]} key(s) in $env_file"
}

cmd_env_get() {
  local target=""
  local profile=""
  local env_file=""
  local keys=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --target=*) target="${1#*=}" ;;
      --target)
        shift
        target="${1:-}"
        ;;
      --profile=*) profile="${1#*=}" ;;
      --profile)
        shift
        profile="${1:-}"
        ;;
      --get=*) keys+=("${1#*=}") ;;
      --get)
        shift
        keys+=("${1:-}")
        ;;
      *) fail "Unknown env:get option: $1" ;;
    esac
    shift || true
  done

  [ -n "$target" ] || fail "env:get requires --target=backend|client|proxy"
  [ -n "$profile" ] || fail "env:get requires --profile=dev|prod"
  [ "${#keys[@]}" -gt 0 ] || fail "env:get requires at least one --get KEY"

  env_file=$(env_resolve_file "$target" "$profile")
  require_file "$env_file"

  local key value
  for key in "${keys[@]}"; do
    is_valid_env_key "$key" || fail "Invalid env key: $key"
    value=$(env_get_value_from_file "$env_file" "$key")
    if [ -n "$value" ]; then
      echo "$key=$value"
    else
      echo "$key="
    fi
  done
}

cmd_env_unset() {
  local target=""
  local profile=""
  local env_file=""
  local keys=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --target=*) target="${1#*=}" ;;
      --target)
        shift
