        ;;
      --unset=*) keys+=("${1#*=}") ;;
      --unset)
        shift
        keys+=("${1:-}")
        ;;
      *) fail "Unknown env:unset option: $1" ;;
    esac
    shift || true
  done

  [ -n "$target" ] || fail "env:unset requires --target=backend|client|proxy"
  [ -n "$profile" ] || fail "env:unset requires --profile=dev|prod"
  [ "${#keys[@]}" -gt 0 ] || fail "env:unset requires at least one --unset KEY"

  env_file=$(env_resolve_file "$target" "$profile")
  require_file "$env_file"

  local key
  for key in "${keys[@]}"; do
    is_valid_env_key "$key" || fail "Invalid env key: $key"
    env_unset_key_in_file "$env_file" "$key"
  done

  log "Removed ${#keys[@]} key(s) from $env_file"
}

cmd_ops_install() {
  local launcher_path="$ROOT_DIR/aera"

  mkdir -p "$ROOT_DIR"
  cat > "$launcher_path" <<EOF
#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="\$(cd "\$(dirname "\${BASH_SOURCE[0]}")" && pwd)"
exec "\$ROOT_DIR/ops/aera" "\$@"
EOF
  chmod +x "$launcher_path"
  log "Root launcher installed: $launcher_path"
}

cmd_ops_install_global() {
  cmd_ops_install

  local launcher_path="$ROOT_DIR/aera"
  if [ -w /usr/local/bin ] || [ ! -e /usr/local/bin/aera ]; then
    ln -sf "$launcher_path" /usr/local/bin/aera
    log "Global command linked: /usr/local/bin/aera -> $launcher_path"
  elif command -v sudo >/dev/null 2>&1; then
    sudo ln -sf "$launcher_path" /usr/local/bin/aera
    log "Global command linked with sudo: /usr/local/bin/aera -> $launcher_path"
  else
    warn "Cannot write /usr/local/bin and sudo is unavailable. Link manually: ln -sf $launcher_path /usr/local/bin/aera"
  fi
}

