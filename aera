cmd_backend_secrets_generate() {
  local profile="prod"
  local show_values="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --profile=*) profile="${1#*=}" ;;
      --profile)
        shift
        profile="${1:-}"
        ;;
      --show) show_values="true" ;;
      *) fail "Unknown backend:secrets:generate option: $1" ;;
    esac
    shift || true
  done

  case "${profile,,}" in
    dev|development) profile="dev" ;;
    prod|production) profile="prod" ;;
    *) fail "backend:secrets:generate requires --profile=dev|prod" ;;
  esac

  require_cmd openssl

  local mongo_password rabbitmq_password jwt_secret refresh_token_key email_otp_secret public_api_key
  mongo_password=$(openssl rand -hex 16)
  rabbitmq_password=$(openssl rand -hex 16)
  jwt_secret=$(openssl rand -hex 64)
  refresh_token_key=$(openssl rand -hex 32)
  email_otp_secret=$(openssl rand -base64 32)
  public_api_key=$(openssl rand -hex 64)

  cmd_env_set \
    --target backend \
    --profile "$profile" \
    --set "MONGO_INITDB_ROOT_PASSWORD=${mongo_password}" \
    --set "RABBITMQ_PASSWORD=${rabbitmq_password}" \
    --set "JWT_SECRET=${jwt_secret}" \
    --set "REFRESH_TOKEN_ENCRYPTION_KEY=${refresh_token_key}" \
    --set "EMAIL_OTP_SECRET=${email_otp_secret}" \
    --set "PUBLIC_API_KEY=${public_api_key}"

  if is_true "$show_values"; then
    echo "Generated backend secrets in profile=$profile"
    echo "MONGO_INITDB_ROOT_PASSWORD=$mongo_password"
    echo "RABBITMQ_PASSWORD=$rabbitmq_password"
    echo "JWT_SECRET=$jwt_secret"
    echo "REFRESH_TOKEN_ENCRYPTION_KEY=$refresh_token_key"
    echo "EMAIL_OTP_SECRET=$email_otp_secret"
    echo "PUBLIC_API_KEY=$public_api_key"
  else
    log "Generated backend secrets in backend profile=$profile"
    warn "Values were written to env file and hidden in output. Use --show only in a secure terminal session if you need to see them."
  fi
}

