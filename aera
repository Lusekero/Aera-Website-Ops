  if docker compose version >/dev/null 2>&1; then
    log "Docker Compose plugin detected"
  else
    fail "Docker Compose plugin is not available"
  fi
  dc --env-file "$BACKEND_ENV" -f "$BACKEND_COMPOSE" config >/dev/null
  dc --env-file "$CLIENT_ENV" -f "$CLIENT_COMPOSE" config >/dev/null
  dc -f "$EDGE_COMPOSE" config >/dev/null
  log "Doctor checks passed"
}

cmd_client_down() {
  ensure_prerequisites
